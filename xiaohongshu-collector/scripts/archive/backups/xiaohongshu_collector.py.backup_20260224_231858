    def random_sleep(self, min_sec=2, max_sec=5):
        """随机延迟"""
        delay = random.uniform(min_sec, max_sec)
        time.sleep(delay)

    def _apply_filters(self, sort, time_filter, note_type=None, search_range=None, location=None):
        """应用筛选条件（鼠标悬停 + 点击方式 - 已验证有效）"""
        if sort == "general" and not time_filter and not note_type and not search_range and not location:
            return

        print("\n📅 应用筛选条件...")

        sort_map = {
            "general":"综合",
            "newest":"最新",
            "most_likes":"最多点赞",
            "most_comments":"最多评论",
            "most_favorites":"最多收藏"
        }
        time_map = {"1d":"一天内","7d":"一周内","180d":"半年内"}
        note_type_map = {"all":"不限","video":"视频","image":"图文"}
        search_range_map = {"all":"不限","viewed":"已看过","unviewed":"未看过","followed":"已关注"}
        location_map = {"all":"不限","local":"同城","nearby":"附近"}

        try:
            print("🖱️  鼠标悬停筛选按钮...")
            filter_btn = self.browser.page.get_by_text("筛选").first
            box = filter_btn.bounding_box()
            if not box: print("⚠️  未找到筛选按钮"); return
            print(f"📍 筛选按钮位置：({box['x']}, {box['y']})")
            self.browser.page.mouse.move(box['x']-100, box['y'])
            self.random_sleep(0.5, 1)
            self.browser.page.mouse.move(box['x']+box['width']/2, box['y']+box['height']/2)
            print("✓ 已悬停筛选按钮")
            self.random_sleep(2, 3)

            filters_applied = []
            if sort and sort != "general":
                t = sort_map.get(sort, sort)
                if self._click_filter_option(t): filters_applied.append(f"排序：{t}"); self.random_sleep(1, 2)
            if note_type and note_type != "all":
                t = note_type_map.get(note_type, note_type)
                if self._click_filter_option(t): filters_applied.append(f"类型：{t}"); self.random_sleep(1, 2)
            if time_filter:
                t = time_map.get(time_filter, time_filter)
                if self._click_filter_option(t): filters_applied.append(f"时间：{t}"); self.random_sleep(1, 2)
            if search_range and search_range != "all":
                t = search_range_map.get(search_range, search_range)
                if self._click_filter_option(t): filters_applied.append(f"范围：{t}"); self.random_sleep(1, 2)
            if location and location != "all":
                t = location_map.get(location, location)
                if self._click_filter_option(t): filters_applied.append(f"位置：{t}"); self.random_sleep(1, 2)

            if filters_applied:
                print(f"✅ 已应用筛选：{', '.join(filters_applied)}")
                for i in range(3): self.browser.page.evaluate("window.scrollBy(0, 800)"); self.random_sleep(1, 2)
            else: print("⚠️  未应用任何筛选")
        except Exception as e: print(f"⚠️  应用筛选失败：{e}")

    def _click_filter_option(self, filter_text):
        """查找并点击筛选选项（尝试多个候选，提高成功率）"""
        try:
            # 获取所有候选元素（不返回element对象，因为无法序列化）
            candidates_data = self.browser.page.evaluate(f"""() => {{
                const all = Array.from(document.querySelectorAll('*'));
                const candidates = [];

                // 特殊处理：对于"视频"和"图文"，只允许精确匹配
                const strictMatch = ['视频', '图文', '不限'].includes('{filter_text}');

                // 收集所有候选元素
                all.forEach((el, index) => {{
                    const text = (el.textContent || '').trim();
                    const rect = el.getBoundingClientRect();

                    // 只考虑可见元素
                    if (rect.width <= 0 || rect.height <= 0) return;

                    // 精确匹配（优先）
                    if (text === '{filter_text}') {{
                        candidates.push({{
                            index: index,
                            text: text,
                            x: rect.x + rect.width / 2,
                            y: rect.y + rect.height / 2,
                            width: rect.width,
                            height: rect.height,
                            priority: 1
                        }});
                    }}
                    // 部分匹配（仅在非严格匹配模式下）
                    else if (!strictMatch && text.includes('{filter_text}') && text.length < 20) {{
                        candidates.push({{
                            index: index,
                            text: text,
                            x: rect.x + rect.width / 2,
                            y: rect.y + rect.height / 2,
                            width: rect.width,
                            height: rect.height,
                            priority: 2
                        }});
                    }}
                }});

                // 按优先级排序，然后按宽度排序（优先选择较小的）
                candidates.sort((a, b) => {{
                    if (a.priority !== b.priority) return a.priority - b.priority;
                    return a.width - b.width;  // 优先选择宽度较小的
                }});

                return candidates;
            }}""")

            if not candidates_data:
                print(f"   未找到选项: {filter_text}")
                return False

            print(f"   找到 {len(candidates_data)} 个候选")

            # 尝试点击每个候选，直到成功
            for i, candidate in enumerate(candidates_data[:3], 1):  # 最多尝试3个
                print(f"   尝试候选 {i}/{min(3, len(candidates_data))}: {candidate['text']} (宽度:{candidate['width']:.0f}x{candidate['height']:.0f})")

                self.browser.page.mouse.move(candidate['x'], candidate['y'])
                self.random_sleep(0.3, 0.6)
                self.browser.page.mouse.click(candidate['x'], candidate['y'])
                self.random_sleep(1, 2)

                # 检查点击是否生效（检查菜单是否消失）
                menu_visible = self.browser.page.evaluate("""() => {
                    const all = Array.from(document.querySelectorAll('*'));
                    return all.some(el => (el.textContent || '').trim() === '收起');
                }""")

                if not menu_visible:
                    print(f"   ✅ 筛选菜单已关闭，点击成功")
                    break
                else:
                    print(f"   ⚠️  菜单仍打开，尝试下一个候选")

            # 如果菜单仍打开，尝试点击"收起"按钮
            menu_still_open = self.browser.page.evaluate("""() => {
                const all = Array.from(document.querySelectorAll('*'));
                return all.some(el => (el.textContent || '').trim() === '收起');
            }""")

            if menu_still_open:
                close_result = self.browser.page.evaluate("""() => {
                    const all = Array.from(document.querySelectorAll('*'));
                    for (let el of all) {
                        const text = (el.textContent || '').trim();
                        if (text === '收起') {
                            const rect = el.getBoundingClientRect();
                            if (rect.width > 0 && rect.height > 0) {
                                return {
                                    x: rect.x + rect.width / 2,
                                    y: rect.y + rect.height / 2
                                };
                            }
                        }
                    }
                    return null;
                }""")

                if close_result:
                    self.browser.page.mouse.click(close_result['x'], close_result['y'])
                    print(f"   ✅ 已关闭筛选菜单")

            # 等待页面刷新
            print(f"   ⏳ 等待页面刷新...")
            time.sleep(5)
            return True
        except Exception as e:
            print(f"   点击失败: {e}")
            return False

