                        # 保存图片（使用 requests 下载，不离开当前页面）
                        if note_data.get('images'):
                            note_images_dir = images_dir / f"{i:03d}"
                            note_images_dir.mkdir(exist_ok=True)

                            for j, img_url in enumerate(note_data['images'][:10], 1):
                                try:
                                    # 使用 requests 下载图片，避免浏览器导航
                                    headers = {
                                        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
                                    }
                                    response = requests.get(img_url, headers=headers, timeout=10)
                                    if response.status_code == 200:
                                        img_path = note_images_dir / f"image_{j}.jpg"
                                        with open(img_path, 'wb') as f:
                                            f.write(response.content)
                                        print(f"   📷 保存图片 {j}/{len(note_data['images'][:10])}")
                                except Exception as e:
                                    print(f"   ⚠️ 图片下载失败: {e}")

                        # 下载视频（如果有）⚠️ 必须在JSON保存之前完成
                        video = note_data.get('video')
                        if self.download_video and video and video.get('download_url'):
                            print("   🎬 下载视频...")
                            video_info = video
                            video_url = video_info.get('download_url')

                            if video_url:
                                try:
                                    # 创建视频目录
                                    videos_dir = save_path / "videos"
                                    videos_dir.mkdir(exist_ok=True)

                                    # 生成文件名
                                    safe_title = re.sub(r'[^\w\u4e00-\u9fff]+', '_', note_data.get('title', 'untitled')[:30])
                                    video_filename = f"{i:03d}_{safe_title}.mp4"
                                    video_path = videos_dir / video_filename

                                    # 下载视频（同步执行，确保在保存JSON前完成）
                                    async def download_video_async():
                                        success = await self.video_downloader.download_video(video_url, video_path)
                                        return success

                                    success = asyncio.run(download_video_async())

                                    if success:
                                        # ⚠️ 关键：立即更新 note_data['video'] 的 local_path
                                        note_data['video']['local_path'] = str(video_path)
                                        print(f"   ✅ 视频已保存: {video_filename}")
                                        print(f"      分辨率: {video_info.get('width')}x{video_info.get('height')}")
                                        print(f"      大小: {video_info.get('size', 0) / 1024 / 1024:.2f} MB")
                                    else:
                                        print(f"   ❌ 视频下载失败")
                                except Exception as e:
                                    print(f"   ❌ 视频下载失败: {e}")

                        # ⚠️ 保存JSON必须在视频下载之后，确保 local_path 已写入
                        safe_title = re.sub(r'[^\w\u4e00-\u9fff]+', '_', note_data.get('title', 'untitled')[:30])
                        note_filename = f"{i:03d}_{safe_title}"
                        note_path = notes_dir / f"{note_filename}.json"

                        with open(note_path, 'w', encoding='utf-8') as f:
                            json.dump(note_data, f, ensure_ascii=False, indent=2)

                        print(f"   ✅ 已保存: {note_path.name}")
                        collected_notes.append(note_data)

                    # 关闭当前页面，返回搜索结果页（避免重新加载触发验证）
                    self._close_current_page()

                    # ⚠️ 关键修复：确保已返回列表页，否则强制返回
                    print("   🔍 确认当前页面...")
                    current_url = self.browser.page.url
                    is_detail_page = '/explore/' in current_url and current_url != start_url

                    if is_detail_page:
                        print("   ⚠️  仍在详情页！尝试强制返回...")
                        # 尝试按ESC键
                        self.browser.page.keyboard.press('Escape')
                        time.sleep(1)

                        # 检查是否成功返回
                        current_url = self.browser.page.url
                        if '/explore/' in current_url:
                            print("   ❌ 强制返回失败，跳过此笔记")
                            continue

                    print("   ⏳ 等待页面稳定...")
                    time.sleep(2)

                except Exception as e:
                    print(f"   ✗ 失败: {e}")
                    import traceback
                    traceback.print_exc()

                    # 尝试关闭当前页面返回
                    try:
                        self._close_current_page()
                        time.sleep(2)  # 等待页面稳定
                    except:
                        pass

            # 保存汇总
            summary = {
                'keyword': keyword,
                'total_notes': len(collected_notes),
                'notes': [
                    {
                        'index': i+1,
                        'title': n.get('title', ''),
                        'url': n.get('url', ''),
                        'author': n.get('author', ''),
                        'comments_count': len(n.get('comments', {}).get('main_comments', []))
                    }
                    for i, n in enumerate(collected_notes)
                ],
                'collected_at': datetime.now().isoformat()
            }

            summary_path = save_path / "summary.json"
            with open(summary_path, 'w', encoding='utf-8') as f:
                json.dump(summary, f, ensure_ascii=False, indent=2)

            print(f"\n{'='*70}")
            print(f"✅ 采集完成！")
            print(f"📊 成功采集 {len(collected_notes)} 个贴子")
            print(f"📁 保存位置: {save_dir}")
            print(f"📋 汇总文件: summary.json")

            return summary

        finally:
            print("\n⏳ 关闭浏览器...")
            self.browser.close()

    def _extract_note_data(self):
        """提取贴子数据"""
        try:
            note_data = {
                'url': self.browser.page.url,
                'collected_at': datetime.now().isoformat()
            }

            # 提取标题
            try:
                title = self.browser.page.evaluate("""
                () => {
                    const titleElem = document.querySelector('div.title[id="detail-title"]');
                    if (titleElem) {
                        return titleElem.innerText.trim();
                    }
                    return '';
                }
                """)
                note_data['title'] = title
                print(f"   📝 标题: {title[:50]}")
            except:
                note_data['title'] = ''

            # 提取作者
            try:
                author = self.browser.page.evaluate("""
                () => {
                    const authorElem = document.querySelector('div[class*="author"]');
                    if (authorElem) {
                        return authorElem.innerText.trim();
                    }
                    return '';
                }
                """)
                note_data['author'] = author
                print(f"   👤 作者: {author}")
            except:
                note_data['author'] = ''

            # 提取正文
            try:
                content = self.browser.page.evaluate("""
                () => {
                    const contentElem = document.querySelector('div[class="note-content"]');
                    if (contentElem) {
                        return contentElem.innerText.trim();
                    }
                    return '';
                }
                """)
                note_data['content'] = content
                print(f"   📄 内容: {len(content)} 字符")
            except:
                note_data['content'] = ''

            # 提取图片URL（只提取贴子正文内的图片）
            try:
                images = self.browser.page.evaluate("""
                () => {
                    const images = new Set();
                    const allImgs = document.querySelectorAll('img');

                    allImgs.forEach(img => {
                        if (img.src && img.src.includes('sns-webpic')) {
                            // 向上查找父元素，确认图片在正文区域内
                            let parent = img.parentElement;
                            let inNote = false;

                            for (let i = 0; i < 5; i++) {
                                if (!parent) break;

                                const pClass = parent.className || '';

                                // 检查父元素 class 是否包含正文标识
                                if (pClass.includes('note-content') ||
                                    pClass.includes('note-slider') ||
                                    pClass.includes('detail')) {
                                    inNote = true;
                                    break;
                                }

                                parent = parent.parentElement;
                            }

                            // 只有在正文区域内的图片才添加
                            if (inNote) {
                                images.add(img.src);
                            }
                        }
                    });

                    return Array.from(images);
                }
                """)
                note_data['images'] = images
                if images:
                    print(f"   📷 正文图片: {len(images)} 张")
                else:
                    print(f"   📷 未找到正文图片（可能是纯文字贴子）")
            except Exception as e:
                print(f"   ⚠️ 图片提取失败: {e}")
                note_data['images'] = []

            # 检测并提取视频信息（使用 VideoDownloader 获取真实下载链接）
            try:
                video_elem = self.browser.page.query_selector('video')

                if video_elem:
                    # 使用 VideoDownloader 从页面源码提取视频流信息
                    html_content = self.browser.page.content()
                    
                    video_data = self.video_downloader.parse_html(html_content) if self.video_downloader else {}

                    if not video_data:
                        print(f"   🎬 检测到视频，但解析失败")
                        print(f"   💡 提示：__INITIAL_STATE__ 可能不存在或格式变化")
                        note_data['video'] = {"has_video": True, "download_url": None}
                    elif self.video_downloader:
                        video_info = self.video_downloader.get_video_info(video_data)

                        if video_info and video_info.get('download_url'):
                            note_data['video'] = video_info
                            print(f"   🎬 检测到视频:")
                            print(f"      分辨率: {video_info.get('width')}x{video_info.get('height')}")
                            print(f"      编码: {video_info.get('codec', 'unknown')}")
                            print(f"      大小: {video_info.get('size', 0) / 1024 / 1024:.2f} MB")
                            print(f"      ✅ 可下载（CDN链接已获取）")
                        else:
                            print(f"   🎬 检测到视频，但无下载链接")
                            note_data['video'] = {"has_video": True, "download_url": None}
                    else:
                        note_data['video'] = {"has_video": True, "download_url": None}
                        print(f"   🎬 检测到视频，但视频下载器未初始化")
                else:
                    note_data['video'] = None
            except Exception as e:
                print(f"   ⚠️ 视频检测失败: {e}")
                import traceback
                traceback.print_exc()
                note_data['video'] = None

            return note_data

        except Exception as e:
            print(f"   ⚠️ 提取失败: {e}")
            return None

    def _close_current_page(self):
        """关闭当前贴子页面，返回搜索结果页（避免重新加载触发验证）"""
        try:
            print("   🔙 关闭当前页面...")

            # 先检查是否有遮罩层（说明还在贴子详情页）
            has_mask = self.browser.page.evaluate("""() => {
                const mask = document.querySelector('[class*="note-detail-mask"]');
                return mask !== null;
            }""")

            if not has_mask:
                print("   ℹ️  已经在搜索结果页，无需关闭")
                return True

            # 方案1: 查找关闭按钮（页面左上角）
            close_selectors = [
                'button[aria-label="关闭"]',
                'button[aria-label="close"]',
                'button[class*="close"]',
                '.close-button',
                '[class*="header-close"]',
                'svg[class*="close"]'  # SVG图标
            ]

            close_btn = None
            for selector in close_selectors:
                try:
                    close_btn = self.browser.page.query_selector(selector)
                    if close_btn:
                        box = close_btn.bounding_box(timeout=1000)
                        if box and box['width'] > 0 and box['height'] > 0:
                            print(f"   ✅ 找到关闭按钮: {selector}")
                            break
                except:
                    continue

            if close_btn:
                close_btn.click()
                print("   ✅ 已点击关闭按钮")
                self.random_sleep(1, 2)
                # 验证是否成功关闭
                mask_gone = self.browser.page.evaluate("""() => {
                    const mask = document.querySelector('[class*="note-detail-mask"]');
                    return mask === null;
                }""")
                if mask_gone:
                    print("   ✅ 已关闭页面")
                    return True
                else:
                    print("   ⚠️ 关闭后仍有遮罩层，尝试其他方法")

            # 方案2: 使用JavaScript查找并点击
            print("   ⚠️ 尝试JavaScript关闭...")
            js_result = self.browser.page.evaluate("""() => {
                // 查找所有可能的关闭元素
                const all = document.querySelectorAll('*');
                for (let el of all) {
                    const text = (el.textContent || '').trim();
                    const rect = el.getBoundingClientRect();
                    const aria = el.getAttribute('aria-label') || '';

                    // 查找左上角的小图标或按钮
                    if (rect.x < 100 && rect.y < 100 &&
                        rect.width > 10 && rect.width < 50 &&
                        rect.height > 10 && rect.height < 50) {
                        // 安全检查className（可能是SVGAnimatedString）
                        const className = String(el.className || '');
                        const hasCloseClass = el.classList ?
                            el.classList.contains('close') :
                            className.includes('close');

                        if (aria === '关闭' || aria === 'close' ||
                            text === '✕' || text === '×' ||
                            hasCloseClass) {
                            el.click();
                            return {success: true, method: 'JS click'};
                        }
                    }
                }
                return {success: false};
            }""")

            if js_result.get('success'):
                print("   ✅ 已关闭页面（JS）")
                self.random_sleep(1, 2)
                return True

            # 方案3: 使用键盘快捷键
            print("   ⚠️ 尝试键盘快捷键...")
            # Alt+Left 在Linux/Mac是不同的，尝试多种方式
            try:
                # 先尝试Alt+Left（Windows/Linux）
                self.browser.page.keyboard.down("Alt")
                self.browser.page.keyboard.press("ArrowLeft")
                self.browser.page.keyboard.up("Alt")
                print("   ✅ 已后退（Alt+Left）")
                self.random_sleep(1, 2)
                return True
            except:
                # 尝试Command+Left（Mac）
                try:
                    self.browser.page.keyboard.down("Meta")
                    self.browser.page.keyboard.press("ArrowLeft")
                    self.browser.page.keyboard.up("Meta")
                    print("   ✅ 已后退（Cmd+Left）")
                    self.random_sleep(1, 2)
                    return True
                except:
                    pass

        except Exception as e:
            print(f"   ⚠️ 关闭失败: {e}")
            return False

    def _extract_comments(self):
        """提取评论（结构化）"""
        try:
            # 检查是否有评论元素
            check_count = self.browser.page.evaluate("""
            () => {
                return document.querySelectorAll('[class*="comment-item"]').length;
            }
            """)
            
            print(f"   🔍 找到 {check_count} 个评论元素")
            
            if check_count == 0:
                print("   ⚠️ 未找到评论元素（可能该贴子无评论）")
                return None

            # 获取评论数据
            data = self.browser.page.evaluate("""
            () => {
                const items = document.querySelectorAll('[class*="comment-item"]');
                return Array.from(items).map((elem, index) => {
                    const text = elem.innerText;
                    const isReply = elem.classList.contains('comment-item-sub') ||
                                   elem.classList.contains('sub-comment');

                    return {
                        index: index,
                        text: text,
                        isReply: isReply
                    };
                });
            }
            """)

            if not data or len(data) == 0:
                print("   ⚠️ 未找到评论")
                return None

            # 解析评论
            main_comments = []
            current_main = None

            for item in data:
                text = item['text']
                lines = [line.strip() for line in text.split('\n') if line.strip()]

                if len(lines) < 2:
                    continue

                # 解析用户名和作者标识
                first_line = lines[0]
                is_author = '作者' in first_line
                user = first_line.replace('作者', '').strip()
                
                # 如果"作者"单独占一行
                if len(lines) > 1 and lines[1] == '作者':
                    is_author = True
                    user = first_line
                    lines = lines[1:]  # 跳过"作者"行

                # 提取内容、日期、点赞
                content = ''
                date = ''
                likes = 0

                for line in lines[1:]:
                    # 跳过标识性文本
                    if line in ['赞', '回复', '作者', '置顶评论']:
                        continue
                    
                    # 匹配日期
                    if re.match(r'^\d{4}-\d{2}-\d{2}', line) or '前' in line or '刚刚' in line or '编辑' in line:
                        date = line
                        continue
                    
                    # 匹配点赞数
                    if line.isdigit():
                        likes = int(line)
                        continue
                    
                    # 其他文本作为内容
                    if len(line) > 1 and not content:
                        content = line

                # 如果没有提取到内容，尝试合并所有非关键行
                if not content:
                    content_parts = []
                    for line in lines[1:]:
                        if line not in ['赞', '回复', '作者', '置顶评论'] and \
                           not re.match(r'^\d{4}-\d{2}-\d{2}', line) and \
                           not line.isdigit() and '前' not in line and '刚刚' not in line:
                            content_parts.append(line)
                    content = ' '.join(content_parts)

                comment_data = {
                    'user': user,
                    'content': content,
                    'date': date,
                    'likes': likes,
                    'is_author': is_author,
                    'replies': []
                }

                # 组织结构（主评论和回复）
                if item['isReply']:
                    # 这是回复，添加到当前主评论
                    if current_main is not None:
                        current_main['replies'].append(comment_data)
                else:
                    # 这是主评论
                    if current_main is not None:
                        main_comments.append(current_main)
                    current_main = comment_data

            # 添加最后一个主评论
            if current_main is not None:
                main_comments.append(current_main)

            if not main_comments:
                print("   ⚠️ 未能解析评论")
                return None

            return {
                'main_comments': main_comments,
                'total_main_comments': len(main_comments),
                'total_replies': sum(len(c['replies']) for c in main_comments)
            }

        except Exception as e:
            print(f"   ⚠️ 评论提取失败: {e}")
            import traceback
            traceback.print_exc()
            return None


def main():
    """命令行入口"""
    import argparse

    parser = argparse.ArgumentParser(description='小红书话题采集器（支持视频下载）')
    parser.add_argument('keyword', help='搜索关键词')
    parser.add_argument('--max', type=int, default=10, help='最多采集几个贴子')
    parser.add_argument('--sort', type=str, default='general', 
                       choices=['general', 'newest', 'hot'],
                       help='排序依据：general=综合, newest=最新, hot=最热')
    parser.add_argument('--time-filter', type=str, default=None,
                       choices=['1d', '7d', '30d', '90d', '365d'],
                       help='时间筛选：1d=一天内, 7d=一周内, 30d=一月内, 90d=三月内, 365d=一年内')
    parser.add_argument('--note-type', type=str, default=None,
                       choices=['all', 'video', 'image'],
                       help='笔记类型：all=不限, video=仅视频, image=仅图文')
    parser.add_argument('--no-video', action='store_true', help='不下载视频（仅记录信息）')

    args = parser.parse_args()

    collector = XiaohongshuCollector(download_video=not args.no_video)
    collector.search_and_collect(
        keyword=args.keyword,
        max_notes=args.max,
        sort=args.sort,
        time_filter=args.time_filter,
        note_type=args.note_type
    )


if __name__ == "__main__":
    main()

